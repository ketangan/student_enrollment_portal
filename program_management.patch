diff --git a/templates/school_admin/program_form.html b/templates/school_admin/program_form.html
new file mode 100644
index 0000000..a0e6883
--- /dev/null
+++ b/templates/school_admin/program_form.html
@@ -0,0 +1,125 @@
+{% extends "school_admin/base.html" %}
+{% block page_title %}{{ form_heading }}{% endblock %}
+
+{% block content %}
+<div class="dash-content">
+  <div class="dash-page-header" style="margin-bottom:20px;">
+    <h1 class="dash-page-title">{{ form_heading }}</h1>
+  </div>
+
+  <div class="dash-card" style="max-width:560px;padding:24px;">
+    <form method="post" action="{{ form_action }}">
+      {% csrf_token %}
+
+      <!-- Name -->
+      <div class="dash-form-group" style="margin-bottom:16px;">
+        <label class="dash-label" for="id_name">Name <span style="color:#ef4444;">*</span></label>
+        <input type="text"
+               id="id_name"
+               name="name"
+               value="{{ values.name }}"
+               class="dash-input{% if errors.name %} dash-input--error{% endif %}"
+               style="width:100%;"
+               placeholder="e.g. Ballet — Beginner">
+        {% if errors.name %}
+        <div class="dash-field-error" style="color:#ef4444;font-size:12px;margin-top:4px;">{{ errors.name }}</div>
+        {% endif %}
+      </div>
+
+      <!-- Code -->
+      <div class="dash-form-group" style="margin-bottom:16px;">
+        <label class="dash-label" for="id_code">
+          Code <span style="color:#ef4444;">*</span>
+          {% if code_locked %}
+          <span style="font-size:11px;font-weight:400;color:var(--dash-muted,#64748b);margin-left:6px;">(locked)</span>
+          {% endif %}
+        </label>
+        <input type="text"
+               id="id_code"
+               name="code"
+               value="{{ values.code }}"
+               class="dash-input{% if errors.code %} dash-input--error{% endif %}{% if code_locked %} dash-input--disabled{% endif %}"
+               style="width:100%;{% if code_locked %}background:var(--dash-bg,#f8fafc);cursor:not-allowed;{% endif %}"
+               placeholder="e.g. ballet_beginner"
+               {% if code_locked %}readonly title="Code cannot be changed because submissions already reference this program."{% endif %}>
+        {% if code_locked %}
+        <div style="font-size:12px;color:var(--dash-muted,#64748b);margin-top:4px;">
+          Code cannot be changed because submissions already reference this program.
+        </div>
+        {% endif %}
+        {% if errors.code %}
+        <div class="dash-field-error" style="color:#ef4444;font-size:12px;margin-top:4px;">{{ errors.code }}</div>
+        {% endif %}
+      </div>
+
+      <!-- Capacity -->
+      <div class="dash-form-group" style="margin-bottom:16px;">
+        <label class="dash-label" for="id_capacity">Capacity <span style="color:var(--dash-muted,#64748b);font-weight:400;font-size:12px;">(leave blank for unlimited)</span></label>
+        <input type="number"
+               id="id_capacity"
+               name="capacity"
+               value="{{ values.capacity }}"
+               class="dash-input{% if errors.capacity %} dash-input--error{% endif %}"
+               style="width:100%;"
+               min="1"
+               placeholder="e.g. 20">
+        {% if errors.capacity %}
+        <div class="dash-field-error" style="color:#ef4444;font-size:12px;margin-top:4px;">{{ errors.capacity }}</div>
+        {% endif %}
+      </div>
+
+      <!-- Display Order -->
+      <div class="dash-form-group" style="margin-bottom:16px;">
+        <label class="dash-label" for="id_display_order">Display Order</label>
+        <input type="number"
+               id="id_display_order"
+               name="display_order"
+               value="{{ values.display_order }}"
+               class="dash-input"
+               style="width:120px;"
+               min="0">
+      </div>
+
+      <!-- Auto-Enroll -->
+      <div class="dash-form-group" style="margin-bottom:12px;">
+        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:14px;">
+          <input type="checkbox"
+                 id="id_auto_enroll"
+                 name="auto_enroll"
+                 value="1"
+                 {% if values.auto_enroll %}checked{% endif %}
+                 onchange="document.getElementById('waitlist-row').style.display=this.checked?'block':'none';">
+          <span>Auto-enroll on submit</span>
+        </label>
+        <div style="font-size:12px;color:var(--dash-muted,#64748b);margin-top:3px;margin-left:24px;">
+          When enabled, new public submissions for this program are automatically set to <strong>Enrolled</strong>
+          (or Waitlisted if at capacity and waitlist is on).
+        </div>
+      </div>
+
+      <!-- Waitlist Enabled (shown only when auto_enroll checked) -->
+      <div id="waitlist-row" style="margin-bottom:16px;margin-left:24px;{% if not values.auto_enroll %}display:none;{% endif %}">
+        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:14px;">
+          <input type="checkbox"
+                 id="id_waitlist_enabled"
+                 name="waitlist_enabled"
+                 value="1"
+                 {% if values.waitlist_enabled %}checked{% endif %}>
+          <span>Enable waitlist when at capacity</span>
+        </label>
+        <div style="font-size:12px;color:var(--dash-muted,#64748b);margin-top:3px;">
+          Requires a capacity limit to be set. Submissions beyond capacity get status <strong>Waitlisted</strong>.
+        </div>
+      </div>
+
+      <!-- Buttons -->
+      <div style="display:flex;gap:10px;margin-top:24px;">
+        <button type="submit" class="dash-btn dash-btn--primary">
+          {% if is_edit %}Save Changes{% else %}Create Program{% endif %}
+        </button>
+        <a href="{{ cancel_url }}" class="dash-btn dash-btn--secondary">Cancel</a>
+      </div>
+    </form>
+  </div>
+</div>
+{% endblock %}
diff --git a/templates/school_admin/programs.html b/templates/school_admin/programs.html
new file mode 100644
index 0000000..a66d933
--- /dev/null
+++ b/templates/school_admin/programs.html
@@ -0,0 +1,99 @@
+{% extends "school_admin/base.html" %}
+{% block page_title %}Programs{% endblock %}
+
+{% block content %}
+<div class="dash-content">
+
+  {% if no_active_warning %}
+  <div class="dash-alert dash-alert--warning" style="margin-bottom:16px;padding:12px 16px;background:#fffbeb;border:1px solid #fcd34d;border-radius:8px;color:#92400e;font-size:13px;">
+    <strong>Warning:</strong> No active programs exist, but <code>{{ program_field_key }}</code> is set as the program field key.
+    New submissions won't have valid program options until you add at least one active program.
+  </div>
+  {% endif %}
+
+  <div class="dash-page-header" style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
+    <h1 class="dash-page-title">Programs</h1>
+    <a href="{{ create_url }}" class="dash-btn dash-btn--primary">+ Add Program</a>
+  </div>
+
+  {% if program_field_key %}
+  <p style="font-size:13px;color:var(--dash-muted,#64748b);margin-bottom:16px;">
+    Program field key: <code>{{ program_field_key }}</code>
+  </p>
+  {% else %}
+  <div style="font-size:13px;color:var(--dash-muted,#64748b);margin-bottom:16px;padding:12px 16px;background:var(--dash-card,#fff);border:1px solid var(--dash-border,#e2e8f0);border-radius:8px;">
+    No <code>program_field_key</code> set on this school. Programs created here won't appear on the form until you set
+    <code>School.program_field_key</code> via Django admin or the seed command.
+  </div>
+  {% endif %}
+
+  {% if programs_summary %}
+  <div class="dash-card" style="overflow:hidden;">
+    <table class="dash-table" style="width:100%;border-collapse:collapse;">
+      <thead>
+        <tr>
+          <th class="dash-th">Name</th>
+          <th class="dash-th">Code</th>
+          <th class="dash-th">Capacity</th>
+          <th class="dash-th">Enrolled</th>
+          <th class="dash-th">Waitlisted</th>
+          <th class="dash-th">Auto-Enroll</th>
+          <th class="dash-th">Active</th>
+          <th class="dash-th">Actions</th>
+        </tr>
+      </thead>
+      <tbody>
+        {% for code, p in programs_summary.items %}
+        <tr class="dash-tr">
+          <td class="dash-td" style="font-weight:500;">{{ p.name }}</td>
+          <td class="dash-td"><code>{{ p.code }}</code></td>
+          <td class="dash-td">
+            {% if p.capacity %}
+              {{ p.enrolled_count }} / {{ p.capacity }}
+            {% else %}
+              <span style="color:var(--dash-muted,#64748b);">Unlimited</span>
+            {% endif %}
+          </td>
+          <td class="dash-td">{{ p.enrolled_count }}</td>
+          <td class="dash-td">{{ p.waitlisted_count }}</td>
+          <td class="dash-td">
+            {% if p.auto_enroll %}
+              <span class="dash-badge dash-badge--green">Yes{% if p.waitlist_enabled %} + Waitlist{% endif %}</span>
+            {% else %}
+              <span class="dash-badge dash-badge--gray">No</span>
+            {% endif %}
+          </td>
+          <td class="dash-td">
+            {% if p.is_active %}
+              <span class="dash-badge dash-badge--green">Active</span>
+            {% else %}
+              <span class="dash-badge dash-badge--gray">Inactive</span>
+            {% endif %}
+          </td>
+          <td class="dash-td" style="white-space:nowrap;">
+            <a href="{% url 'school_program_edit' school.slug p.id %}"
+               class="dash-btn dash-btn--sm dash-btn--secondary">Edit</a>
+            <form method="post"
+                  action="{% url 'school_program_deactivate' school.slug p.id %}"
+                  style="display:inline;"
+                  onsubmit="return confirm('{% if p.has_submissions %}Deactivate (submissions will be preserved){% else %}Delete{% endif %} program \'{{ p.name }}\'?');">
+              {% csrf_token %}
+              <button type="submit" class="dash-btn dash-btn--sm dash-btn--danger">
+                {% if p.has_submissions %}Deactivate{% else %}Delete{% endif %}
+              </button>
+            </form>
+          </td>
+        </tr>
+        {% endfor %}
+      </tbody>
+    </table>
+  </div>
+  {% else %}
+  <div class="dash-card" style="padding:32px;text-align:center;color:var(--dash-muted,#64748b);">
+    <p style="font-size:15px;margin:0 0 12px;">No programs yet.</p>
+    <a href="{{ create_url }}" class="dash-btn dash-btn--primary">Add your first program</a>
+  </div>
+  {% endif %}
+
+</div>
+{% endblock %}
